{
  "expo": {
    "name": "SAMM",
    "slug": "samm-app",
    "scheme": "samm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/logoapp.png",
    "platforms": [
      "android"
    ],
    "sdkVersion": "54.0.0",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#14EC5C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.samm.app",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "USE_FULL_SCREEN_INTENT",
        "VIBRATE",
        "WAKE_LOCK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoapp.png",
        "backgroundColor": "#1A1D21"
      }
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "scopes": [
            "profile",
            "email"
          ],
          "iosUrlScheme": "com.googleusercontent.apps.238255168182-2k6sgdo7moek39stcpdm4jo4otbpmovl"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La aplicación necesita acceder a tu ubicación para funciones de seguimiento."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logoapp.png",
          "color": "#14EC5C",
          "sounds": ["./assets/SonidoAlarma.mp3"]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "4485bdc1-955f-4d0a-b42e-6d52bda26196"
      }
    },
    "owner": "fernandovargas15"
  }
}